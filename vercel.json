{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/", "destination": "/controller", "permanent": false }
  ],
  "rewrites": [
    { "source": "/controller", "destination": "/src/controller/index.html" },
    { "source": "/controller/(.*)", "destination": "/src/controller/index.html" },
    { "source": "/display", "destination": "/src/display/index.html" },
    { "source": "/display/(.*)", "destination": "/src/display/index.html" }
  ]
}
