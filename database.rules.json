{
  "rules": {
    "rooms": {
      "$uid": {
        "state": {
          ".read": true,
          ".write": "auth.uid === $uid"
        },
        "presence": {
          ".read": "auth.uid === $uid",
          ".write": "auth != null"
        }
      }
    },
    "pairing": {
      "$pairingId": {
        ".read": true,
        ".write": "auth != null"
      }
    }
  }
}
